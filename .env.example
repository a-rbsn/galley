# Reddit asks all clients to identify themselves on every request. The
# format below — `web:<bundle>:v<version> (by /u/<username>)` — is the
# format Reddit recommends. Replace the username with your own.
REDDIT_USER_AGENT=web:io.galley.app:v0.1.0 (by /u/PLACEHOLDER)

# Optional. If set, setup, settings, and subreddit-list changes require
# this password through browser HTTP Basic Auth.
# GALLEY_ADMIN_PASSWORD=replace-me

# Galley defaults to noindex for personal instances. Set to 1 if you want
# search engines to index your deployment.
# GALLEY_ALLOW_INDEXING=1
